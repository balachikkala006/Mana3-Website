# Copy to wrangler.toml and deploy: npx wrangler deploy
# Or paste workers/telegram-quote.js into the Cloudflare dashboard editor.

name = "mana3-telegram-quote"
main = "telegram-quote.js"
compatibility_date = "2024-01-01"

# Set secrets in dashboard (never commit real tokens):
#   wrangler secret put TELEGRAM_BOT_TOKEN
#   wrangler secret put TELEGRAM_CHAT_ID
# Optional:
#   wrangler secret put ALLOWED_ORIGIN

[vars]
# ALLOWED_ORIGIN = "https://yourdomain.com"
